<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Document</title>
</head>
<body class="text-white">
    <div class="main w-full min-h-screen bg-zinc-900 p-10">
<a class="text-blue-500 inline-block mb-10"  href="/">Go Back Home</a>  
<!-- start -->
<form action="/edit" method="post">
                <input class="block w-1/4 rounded-md px-5 py-2 bg-zinc-800 " type="text" placeholder="Previous Name" name="previous"  value="<%=filename%> ">
                <input class="block w-1/4 rounded-md px-5 py-2 bg-zinc-800 mt-2" type="text" placeholder="New Name" name="new">
                <!-- <textarea class="block w-full rounded-md mt-2 px-5 py-2 resize-none bg-zinc-800 " placeholder="Write Details" name="details" ></textarea> -->
                <input class="mt-2 bg-yellow-600 px-5 py-2 rounded-md"  type="submit" value="Rename">
            </form>
<!-- end -->
    </div>
</body>
</html>